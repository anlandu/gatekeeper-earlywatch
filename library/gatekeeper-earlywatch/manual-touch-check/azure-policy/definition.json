{
  "properties": {
    "displayName": "EarlyWatch: ManualTouchCheck - block recently touched workloads",
    "policyType": "Custom",
    "mode": "Microsoft.Kubernetes.Data",
    "description": "Denies UPDATEs to Deployments touched manually within the configured window; backed by external-data provider.",
    "metadata": { "category": "Kubernetes" },
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": { "displayName": "Effect", "description": "deny | audit | disabled" },
        "allowedValues": ["audit", "deny", "disabled"],
        "defaultValue": "deny"
      },
      "excludedNamespaces": {
        "type": "Array",
        "metadata": { "displayName": "Namespaces to exclude" },
        "defaultValue": ["kube-system", "gatekeeper-system", "azure-arc", "azure-extensions-usage-system"]
      },
      "namespaces": {
        "type": "Array",
        "metadata": { "displayName": "Namespaces to include (empty = all)" },
        "defaultValue": []
      },
      "labelSelector": {
        "type": "Object",
        "metadata": { "displayName": "Kubernetes label selector" },
        "defaultValue": {}
      }
    },
    "policyRule": {
      "if": {
        "field": "type",
        "in": [
          "Microsoft.ContainerService/managedClusters",
          "Microsoft.Kubernetes/connectedClusters",
          "AKS Engine"
        ]
      },
      "then": {
        "effect": "[parameters('effect')]",
        "details": {
          "templateInfo": {
            "sourceType": "PublicURL",
            "url": "https://raw.githubusercontent.com/anlandu/gatekeeper-earlywatch/refs/heads/main/library/gatekeeper-earlywatch/manual-touch-check/template.yaml"
          },
          "apiGroups": ["apps"],
          "kinds": ["Deployment"],
          "namespaces": "[parameters('namespaces')]",
          "excludedNamespaces": "[parameters('excludedNamespaces')]",
          "labelSelector": "[parameters('labelSelector')]",
          "values": {"operations": ["UPDATE"], "windowDuration": "2h", "provider": "manual-touch-provider", "failureMode": "Ignore"}
        }
      }
    }
  }
}
