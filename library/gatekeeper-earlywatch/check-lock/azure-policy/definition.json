{
  "properties": {
    "displayName": "EarlyWatch: CheckLock - deny mutation of locked resources",
    "policyType": "Custom",
    "mode": "Microsoft.Kubernetes.Data",
    "description": "Denies update/delete of resources carrying earlywatch.io/lock annotation.",
    "metadata": {
      "category": "Kubernetes"
    },
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "deny | audit | disabled"
        },
        "allowedValues": [
          "audit",
          "deny",
          "disabled"
        ],
        "defaultValue": "deny"
      },
      "excludedNamespaces": {
        "type": "Array",
        "metadata": {
          "displayName": "Namespaces to exclude"
        },
        "defaultValue": [
          "kube-system",
          "gatekeeper-system",
          "azure-arc",
          "azure-extensions-usage-system"
        ]
      },
      "namespaces": {
        "type": "Array",
        "metadata": {
          "displayName": "Namespaces to include (empty = all)"
        },
        "defaultValue": []
      },
      "labelSelector": {
        "type": "Object",
        "metadata": {
          "displayName": "Kubernetes label selector"
        },
        "defaultValue": {}
      }
    },
    "policyRule": {
      "if": {
        "field": "type",
        "in": [
          "Microsoft.ContainerService/managedClusters",
          "Microsoft.Kubernetes/connectedClusters",
          "AKS Engine"
        ]
      },
      "then": {
        "effect": "[parameters('effect')]",
        "details": {
          "templateInfo": {
            "sourceType": "Base64Encoded",
            "content": ""
          },
          "apiGroups": [
            "apps",
            "autoscaling"
          ],
          "kinds": [
            "Deployment",
            "Scale"
          ],
          "namespaces": "[parameters('namespaces')]",
          "excludedNamespaces": "[parameters('excludedNamespaces')]",
          "labelSelector": "[parameters('labelSelector')]",
          "values": {
            "lockOnMutate": true,
            "annotation": "earlywatch.io/lock"
          }
        }
      }
    }
  }
}