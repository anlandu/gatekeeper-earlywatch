{
  "properties": {
    "displayName": "EarlyWatch: CheckLock - deny mutation of locked resources",
    "policyType": "Custom",
    "mode": "Microsoft.Kubernetes.Data",
    "description": "Denies configured operations on resources carrying earlywatch.io/lock annotation.",
    "metadata": {
      "category": "Kubernetes"
    },
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "deny | audit | disabled"
        },
        "allowedValues": [
          "audit",
          "deny",
          "disabled"
        ],
        "defaultValue": "deny"
      },
      "excludedNamespaces": {
        "type": "Array",
        "metadata": {
          "displayName": "Namespaces to exclude"
        },
        "defaultValue": [
          "kube-system",
          "gatekeeper-system",
          "azure-arc",
          "azure-extensions-usage-system"
        ]
      },
      "namespaces": {
        "type": "Array",
        "metadata": {
          "displayName": "Namespaces to include (empty = all)"
        },
        "defaultValue": []
      },
      "labelSelector": {
        "type": "Object",
        "metadata": {
          "displayName": "Kubernetes label selector"
        },
        "defaultValue": {}
      },
      "operations": {
        "type": "Array",
        "metadata": {
          "displayName": "Restricted operations",
          "description": "AdmissionReview operations denied while the lock annotation is set. Subset of CREATE/UPDATE/DELETE/CONNECT."
        },
        "allowedValues": [
          "CREATE",
          "UPDATE",
          "DELETE",
          "CONNECT"
        ],
        "defaultValue": [
          "DELETE",
          "UPDATE"
        ]
      },
      "lockOnMutate": {
        "type": "Boolean",
        "metadata": {
          "displayName": "Lock on mutate",
          "description": "When true, mutations of the lock annotation itself are also denied."
        },
        "defaultValue": true
      }
    },
    "policyRule": {
      "if": {
        "field": "type",
        "in": [
          "Microsoft.ContainerService/managedClusters",
          "Microsoft.Kubernetes/connectedClusters",
          "AKS Engine"
        ]
      },
      "then": {
        "effect": "[parameters('effect')]",
        "details": {
          "templateInfo": {
            "sourceType": "PublicURL",
            "url": "https://raw.githubusercontent.com/anlandu/gatekeeper-earlywatch/refs/heads/main/library/gatekeeper-earlywatch/check-lock/template.yaml"
          },
          "apiGroups": [
            "apps",
            "autoscaling"
          ],
          "kinds": [
            "Deployment",
            "Scale"
          ],
          "namespaces": "[parameters('namespaces')]",
          "excludedNamespaces": "[parameters('excludedNamespaces')]",
          "labelSelector": "[parameters('labelSelector')]",
          "values": {
            "operations": "[parameters('operations')]",
            "annotation": "earlywatch.io/lock",
            "lockOnMutate": "[parameters('lockOnMutate')]"
          }
        }
      }
    }
  }
}
