{
  "properties": {
    "displayName": "EarlyWatch: ExistingResources (static selector) - block Service delete with production Pods",
    "policyType": "Custom",
    "mode": "Microsoft.Kubernetes.Data",
    "description": "Denies Service DELETE when a Pod with tier label in {production,staging} exists in the same namespace.",
    "metadata": { "category": "Kubernetes" },
    "parameters": {
      "effect": { "type": "String", "allowedValues": ["audit", "deny", "disabled"], "defaultValue": "deny" },
      "excludedNamespaces": { "type": "Array", "defaultValue": ["kube-system", "gatekeeper-system", "azure-arc", "azure-extensions-usage-system"] },
      "namespaces": { "type": "Array", "defaultValue": [] },
      "labelSelector": { "type": "Object", "defaultValue": {} }
    },
    "policyRule": {
      "if": {
        "field": "type",
        "in": [
          "Microsoft.ContainerService/managedClusters",
          "Microsoft.Kubernetes/connectedClusters",
          "AKS Engine"
        ]
      },
      "then": {
        "effect": "[parameters('effect')]",
        "details": {
          "templateInfo": { "sourceType": "Base64Encoded", "content": "" },
          "apiGroups": [""],
          "kinds": ["Service"],
          "namespaces": "[parameters('namespaces')]",
          "excludedNamespaces": "[parameters('excludedNamespaces')]",
          "labelSelector": "[parameters('labelSelector')]",
          "values": { "operations": ["DELETE"] }
        }
      }
    }
  }
}
