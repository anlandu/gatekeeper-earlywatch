{
  "properties": {
    "displayName": "EarlyWatch: ExistingResources (field selector) - block Service delete with matching Pods",
    "policyType": "Custom",
    "mode": "Microsoft.Kubernetes.Data",
    "description": "Denies operations on a Service when a Pod in the same namespace matches spec.selector.",
    "metadata": { "category": "Kubernetes" },
    "parameters": {
      "effect": { "type": "String", "allowedValues": ["audit", "deny", "disabled"], "defaultValue": "deny" },
      "excludedNamespaces": { "type": "Array", "defaultValue": ["kube-system", "gatekeeper-system", "azure-arc", "azure-extensions-usage-system"] },
      "namespaces": { "type": "Array", "defaultValue": [] },
      "labelSelector": { "type": "Object", "defaultValue": {} },
      "operations": { "type": "Array", "metadata": { "displayName": "Operations to deny" }, "defaultValue": ["DELETE"] }
    },
    "policyRule": {
      "if": {
        "field": "type",
        "in": [
          "Microsoft.ContainerService/managedClusters",
          "Microsoft.Kubernetes/connectedClusters",
          "AKS Engine"
        ]
      },
      "then": {
        "effect": "[parameters('effect')]",
        "details": {
          "templateInfo": { "sourceType": "PublicURL", "url": "https://raw.githubusercontent.com/anlandu/gatekeeper-earlywatch/refs/heads/main/library/gatekeeper-earlywatch/existing-resources/template.yaml" },
          "apiGroups": [""],
          "kinds": ["Service"],
          "namespaces": "[parameters('namespaces')]",
          "excludedNamespaces": "[parameters('excludedNamespaces')]",
          "labelSelector": "[parameters('labelSelector')]",
          "values": { "operations": "[parameters('operations')]" }
        }
      }
    }
  }
}
