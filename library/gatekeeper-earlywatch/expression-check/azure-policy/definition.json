{
  "properties": {
    "displayName": "EarlyWatch: ExpressionCheck - regex deny on namespace/name",
    "policyType": "Custom",
    "mode": "Microsoft.Kubernetes.Data",
    "description": "Denies operations whose namespace or name matches the configured regex patterns.",
    "metadata": { "category": "Kubernetes" },
    "parameters": {
      "effect": {
        "type": "String",
        "allowedValues": ["audit", "deny", "disabled"],
        "defaultValue": "deny"
      },
      "excludedNamespaces": { "type": "Array", "defaultValue": ["kube-system", "gatekeeper-system", "azure-arc", "azure-extensions-usage-system"] },
      "namespaces": { "type": "Array", "defaultValue": [] },
      "labelSelector": { "type": "Object", "defaultValue": {} },
      "kinds": { "type": "Array", "metadata": { "displayName": "Kinds to match" }, "defaultValue": ["ConfigMap"] },
      "operations": { "type": "Array", "metadata": { "displayName": "Operations to deny" }, "defaultValue": ["DELETE"] },
      "namespacePattern": { "type": "String", "metadata": { "displayName": "Regex matched against the request namespace" }, "defaultValue": "^prod.*" },
      "namePattern": { "type": "String", "metadata": { "displayName": "Regex matched against the resource name" }, "defaultValue": "^critical-.*" }
    },
    "policyRule": {
      "if": {
        "field": "type",
        "in": [
          "Microsoft.ContainerService/managedClusters",
          "Microsoft.Kubernetes/connectedClusters",
          "AKS Engine"
        ]
      },
      "then": {
        "effect": "[parameters('effect')]",
        "details": {
          "templateInfo": { "sourceType": "PublicURL", "url": "https://raw.githubusercontent.com/anlandu/gatekeeper-earlywatch/refs/heads/main/library/gatekeeper-earlywatch/expression-check/template.yaml" },
          "apiGroups": [""],
          "kinds": "[parameters('kinds')]",
          "namespaces": "[parameters('namespaces')]",
          "excludedNamespaces": "[parameters('excludedNamespaces')]",
          "labelSelector": "[parameters('labelSelector')]",
          "values": {
            "operations": "[parameters('operations')]",
            "namespacePattern": "[parameters('namespacePattern')]",
            "namePattern": "[parameters('namePattern')]"
          }
        }
      }
    }
  }
}
